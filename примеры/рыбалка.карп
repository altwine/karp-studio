алг Рыбалка

перечисление Рыба:
    Сом
    Карп
    Тарань
    Карась

функция получить_ценность_рыбы(название: Рыба) -> целое:
    выбор название:
        случай Сом:
        	вернуть 100
        случай Карп:
        	вернуть 250
        случай Тарань:
        	вернуть 300
        случай Карась:
        	вернуть 5000
        иначе:
            печать("Неизвестный вид рыбы")
            вернуть 0

счёт := 0
пока счёт < 100000:
    улов := случайный_элемент(Рыба)
    печать("Вы поймали:", улов)
    счёт += получить_ценность_рыбы(улов)

печать("Победа! Ваш счёт:", счёт, "очков")
