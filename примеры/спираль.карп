функция установить_цвет(номер: цел):
    если номер == 1:
        цвет_пера(255, 0, 0)
    иначе:
        если номер == 2:
            цвет_пера(0, 255, 0)
        иначе:
            если номер == 3:
                цвет_пера(255, 255, 0)
            иначе:
                цвет_пера(255, 0, 255)

функция рисовать_спираль(шаг: цел, длина: вещ, номер_цвета: цел):
    если шаг <= 0:
        вернуть
    установить_цвет(номер_цвета)
    вперед(длина)
    налево(угол)
    новый_номер := номер_цвета + 1
    если новый_номер > 4:
        новый_номер = 1
    рисовать_спираль(шаг - 1, длина + 2, новый_номер)

