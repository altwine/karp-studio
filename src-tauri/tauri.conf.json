{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "karp-studio",
	"version": "0.1.0",
	"identifier": "com.altwine.karp-studio",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist",
		"removeUnusedCommands": true
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"backgroundColor": "#1e1e1e",
				"decorations": false,
				"title": "Karp Studio",
				"width": 1080,
				"height": 720,
				"center": true
			}
		],
		"security": {
			"csp": "default-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;"
		}
	},
	"bundle": {
		"active": true,
		"targets": "nsis",
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
	}
}
